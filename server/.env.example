# Conexión a PostgreSQL para Prisma
# Formato: postgresql://usuario:contraseña@host:puerto/basededatos?schema=public
DATABASE_URL="postgresql://postgres:tu_contraseña_segura@localhost:5432/classboard_db?schema=public"

